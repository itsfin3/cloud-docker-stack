server {
    listen 80 default_server;
    server_name ${DOMAIN_1_DEFAULT};

    location /.well-known/acme-challenge/ {
        root /usr/share/nginx/html/${DOMAIN_1_DEFAULT};
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl default_server;
    server_name ${DOMAIN_1_DEFAULT};

    ssl_certificate     /etc/letsencrypt/live/${DOMAIN_1_DEFAULT}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN_1_DEFAULT}/privkey.pem;

    root /usr/share/nginx/html/${DOMAIN_1_DEFAULT};
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
