# Change these values before deploying
# WG_HOST: domain or public IP peers will connect to
WG_HOST=itsfin3.com

# PASSWORD_HASH: bcrypt hash of the web UI password. Wrap in single quotes -
# bcrypt hashes contain $ characters.
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
PASSWORD_HASH=''

# Client IP range (x will be replaced with client number)
WG_DEFAULT_ADDRESS=30.30.0.x

# DNS server pushed to clients
WG_DEFAULT_DNS=1.1.1.1

# WireGuard listen port (udp) and web UI port (tcp)
WG_PORT=51824
WG_UI_PORT=51825

# Routed to clients: full internet (this stack does NAT egress), and NAT keepalive interval
WG_ALLOWED_IPS=0.0.0.0/0, ::/0
WG_PERSISTENT_KEEPALIVE=25

# This stack's own client subnet (for MASQUERADE + isolation rules), gateway IP, and the one client allowed to reach it
WG_SUBNET=30.30.0.0/24
WG_GATEWAY_IP=30.30.0.1
WG_UI_ACCESS_IP=30.30.0.2

# This stack's docker-bridge network (separate address space from the WireGuard
# tunnel subnet above) - this stack's own pinned IP on it, and wg-main's pinned
# IP on the same bridge (isolation exception target, see WG_POST_UP comment in
# docker-compose.yml). wg-main routes to WG_SUBNET above via WG_SELF_BRIDGE_IP
# as next-hop. WG_MAIN_BRIDGE_IP must match wg-main's own .env.
WG_HOBBY_PUBLIC_BRIDGE_CIDR=172.30.20.0/24
WG_SELF_BRIDGE_IP=172.30.20.2
WG_MAIN_BRIDGE_IP=172.30.20.10

# Other VPN subnets + generic RFC1918/loopback ranges this tunnel must NOT be
# able to reach (isolation rules in docker-compose.yml). Update if those
# stacks' subnets ever change.
MAIN_VPN_SUBNET=10.10.0.0/24
HOBBY_PRIVATE_SUBNET=20.20.0.0/24
RFC1918_LOOPBACK=127.0.0.0/8
RFC1918_10=10.0.0.0/8
RFC1918_172=172.16.0.0/12
RFC1918_192=192.168.0.0/16
