# Change these values before deploying
# WG_HOST: domain or public IP peers will connect to
WG_HOST=itsfin3.com

# WG_PASSWORD_HASH: bcrypt hash of the web UI password
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
WG_PASSWORD_HASH=

# Client IP range (x will be replaced with client number)
WG_DEFAULT_ADDRESS=20.20.0.x

# DNS server pushed to clients
WG_DEFAULT_DNS=1.1.1.1

# WireGuard listen port (udp) and web UI port (tcp)
WG_PORT=51822
WG_UI_PORT=51823

# Subnet routed to clients, and NAT keepalive interval
WG_ALLOWED_IPS=20.20.0.0/24
WG_PERSISTENT_KEEPALIVE=25

# Gateway IP (wg-easy itself) and the one client allowed to reach it, for isolation rules
WG_GATEWAY_IP=20.20.0.1
WG_UI_ACCESS_IP=20.20.0.2
