# Change these values before deploying
DOMAIN=itsfin3.com
BIND_IP=127.0.0.1
PORTAINER_PORT=9443

# This stack owns server-net (docker bridge shared by portainer/grafana/
# prometheus/mysql/wg-main) - changing this and redeploying recreates it,
# same as plus-infra-net/wg-hobby-private/wg-hobby-public.
SERVER_NET_CIDR=172.18.0.0/16
