# Change these values before deploying
# WG_HOST: domain or public IP peers will connect to
WG_HOST=itsfin3.com

# PASSWORD_HASH: bcrypt hash of the web UI password. Wrap in single quotes -
# bcrypt hashes contain $ characters.
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
PASSWORD_HASH=''

# Client IP range (x will be replaced with client number)
WG_DEFAULT_ADDRESS=10.10.0.x

# DNS server pushed to clients - the dns-relay stack's pinned IP (resolves
# server-net container names + hobby/plus container names for free, see
# docker/server-management/dns-relay). Must be a server-net address -
# WG_ALLOWED_IPS below routes 172.18.0.0/16 into the tunnel, so this is
# reachable; the hobby-wg bridge subnets aren't in that list, so a DNS
# server pinned there would never actually receive client queries.
WG_DEFAULT_DNS=172.18.0.53

# WireGuard listen port (udp) and web UI port (tcp)
WG_PORT=51820
WG_UI_PORT=51821

# Subnets routed to clients, and NAT keepalive interval. Own tunnel +
# server-net (direct container reachability, e.g. grafana/portainer) + the
# 3 tunnel-client subnets reachable via the routes below + the 3 hobby/plus
# bridge subnets themselves - needed because each wg-easy web UI (51823,
# 51825, 51827) listens on its bridge IP specifically (e.g. 172.30.10.2),
# not anywhere inside its own tunnel-client range, so that address has to
# be routable too or the UI is unreachable even though the tunnel-client
# range is.
WG_OWN_SUBNET=10.10.0.0/24
SERVER_NET_SUBNET=172.18.0.0/16
HOBBY_PRIVATE_SUBNET=20.20.0.0/24
HOBBY_PUBLIC_SUBNET=30.30.0.0/24
PLUS_VPN_SUBNET=40.40.0.0/24
WG_HOBBY_PRIVATE_BRIDGE_CIDR=172.30.10.0/24
WG_HOBBY_PUBLIC_BRIDGE_CIDR=172.30.20.0/24
WG_PLUS_BRIDGE_CIDR=172.19.44.0/24
WG_ALLOWED_IPS=10.10.0.0/24, 172.18.0.0/16, 20.20.0.0/24, 30.30.0.0/24, 40.40.0.0/24, 172.30.10.0/24, 172.30.20.0/24, 172.19.44.0/24
WG_PERSISTENT_KEEPALIVE=25

# wg-main's own pinned IP on each isolated bridge network (used below only
# for the networks: ipv4_address assignment).
WG_HOBBY_PRIVATE_BRIDGE_IP=172.30.10.10
WG_HOBBY_PUBLIC_BRIDGE_IP=172.30.20.10
WG_PLUS_BRIDGE_IP=172.19.44.10

# Each target stack's OWN pinned bridge IP (= that stack's WG_SELF_BRIDGE_IP
# in its own .env) - this is the actual next-hop gateway for the routes
# below. Do not confuse with the WG_*_BRIDGE_IP vars above, which are
# wg-main's own address on the same bridge, not a valid gateway to route
# via (a route whose gateway is your own local address never forwards -
# this was live-broken as a self-referencing route until fixed 2026-07-22).
WG_HOBBY_PRIVATE_TARGET_IP=172.30.10.2
WG_HOBBY_PUBLIC_TARGET_IP=172.30.20.2
WG_PLUS_TARGET_IP=172.19.44.2
