# Change these values before deploying
# WG_HOST: domain or public IP peers will connect to
WG_HOST=itsfin3.com

# PASSWORD_HASH: bcrypt hash of the web UI password. Wrap in single quotes -
# bcrypt hashes contain $ characters.
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
PASSWORD_HASH=''

# Client IP range (x will be replaced with client number)
WG_DEFAULT_ADDRESS=10.10.0.x

# DNS server pushed to clients - the dns-relay stack's pinned IP (resolves
# server-net container names + hobby/plus container names for free, see
# docker/server-management/dns-relay). Must be a server-net address -
# WG_ALLOWED_IPS below routes 172.18.0.0/16 into the tunnel, so this is
# reachable; the hobby-wg bridge subnets aren't in that list, so a DNS
# server pinned there would never actually receive client queries.
WG_DEFAULT_DNS=172.18.0.53

# WireGuard listen port (udp) and web UI port (tcp)
WG_PORT=51820
WG_UI_PORT=51821

# Subnets routed to clients, and NAT keepalive interval. Own tunnel + server-net
# (direct container reachability, e.g. grafana/portainer) + the 3 tunnel-client
# subnets reachable via the routes below (NOT their docker-bridge subnets -
# clients never address those directly, only the actual WG tunnel ranges).
WG_OWN_SUBNET=10.10.0.0/24
SERVER_NET_SUBNET=172.18.0.0/16
HOBBY_PRIVATE_SUBNET=20.20.0.0/24
HOBBY_PUBLIC_SUBNET=30.30.0.0/24
PLUS_VPN_SUBNET=40.40.0.0/24
WG_ALLOWED_IPS=10.10.0.0/24, 172.18.0.0/16, 20.20.0.0/24, 30.30.0.0/24, 40.40.0.0/24
WG_PERSISTENT_KEEPALIVE=25

# wg-main's pinned IP on each isolated bridge network, and the peer stack's own
# pinned bridge IP (next-hop for the routes above). Must match the corresponding
# WG_MAIN_BRIDGE_IP / WG_SELF_BRIDGE_IP values in each target stack's own .env.
WG_HOBBY_PRIVATE_BRIDGE_IP=172.30.10.10
WG_HOBBY_PUBLIC_BRIDGE_IP=172.30.20.10
WG_PLUS_BRIDGE_IP=172.19.44.10
