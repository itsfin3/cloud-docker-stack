# Pinned IP on server-net - this is the rendezvous address wg-main pushes
# to its clients as WG_DEFAULT_DNS (see that stack's .env). The two values
# must match. Must be a server-net address (172.18.0.0/16) specifically -
# that's the range wg-main's WG_ALLOWED_IPS actually routes into the
# tunnel, unlike the hobby-wg bridge subnets.
DNS_RELAY_BRIDGE_IP=172.18.0.53
